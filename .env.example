# Vite env vars (copie este arquivo para `.env` ou `.env.local` e preencha)
#
# URL do projeto Supabase (Project settings → API → Project URL)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Chave pública para frontend (Project settings → API → anon/public ou publishable key)
# Nunca use service_role no client.
VITE_SUPABASE_ANON_KEY="YOUR_PUBLIC_SUPABASE_KEY"

# Opcional: URL do dev server (Electron em desenvolvimento; o plugin Vite define quando aplicável)
# VITE_DEV_SERVER_URL="http://localhost:5173"

