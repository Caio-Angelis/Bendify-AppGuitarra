# Dependencies
node_modules/

# Build & bundler output
dist/
dist-electron/
dist-ssr/
dist-installer/
build/
out/
release/
*.local

# Emitted JS next to TypeScript sources
electron/**/*.js

# Environment — keys e URLs do Supabase / API (nunca versionar)
.env
.env.*
!.env.example

# Cookies, sessão de ferramentas e navegador (yt-dlp, etc.)
*cookies*.txt
cookies.txt
.netrc
*.session

# Dados locais / filas pessoais (use `*.example` ou `links.example.txt` como modelo)
links.txt
*.db
*.sqlite
*.sqlite3

# Saídas e análises geradas localmente
resultados/
outputs/
analise/
temp/
tmp/
scraped/
downloads/
local-media/

# Mídia e legendas grandes (downloads/scraper); manter versionados apenas em public/ e skins/
*.mp4
*.webm
*.mkv
*.mp3
*.wav
*.flac
*.aac
*.m4a
*.srt
*.vtt
!public/
!public/**
!skins/
!skins/**

# Python (scripts auxiliares)
venv/
.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/

# Ambientes virtuais genéricos
.envrc

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Tests & coverage
coverage/
*.lcov

# TypeScript incremental
*.tsbuildinfo

# Tooling caches
.vite/
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.pid
*.seed
*.pid.lock

# Package managers (artefatos locais; lockfiles permanecem versionados)
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.npm/
.pnpm-store/

