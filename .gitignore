.vscode/*
!.vscode/extensions.json
.idea/
*.iml
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln

# Sistema — macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Sistema — Windows
Thumbs.db
