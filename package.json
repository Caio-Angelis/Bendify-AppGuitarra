{
  "name": "bendify",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -b && vite build",
    "dist": "npm run build:electron && electron-builder",
    "dist:win": "npm run build:electron && electron-builder --win nsis",
    "dist:win:ci": "npm run build:electron && electron-builder --win nsis --publish never",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "audit:deps": "npm audit --audit-level=high",
    "audit:deps:critical": "npm audit --audit-level=critical",
    "repo:publish-bendify-app": "node scripts/publish-bendify-app.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.101.1",
    "lucide-react": "^0.468.0",
    "pitchfinder": "^2.3.4",
    "pixi-dragonbones-runtime": "7.0.0",
    "pixi.js": "7.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tone": "^15.1.22",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.bendify.app",
    "productName": "Bendify",
    "forceCodeSigning": false,
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "icon.ico",
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
